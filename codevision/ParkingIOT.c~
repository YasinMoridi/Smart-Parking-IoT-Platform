/*****************************************************
Project : Smart Parking Access Control System
Version : 2.1 - ATmega16 Port
Author  : Yasin Moridi

Hardware:
  - ATmega16 @ 8MHz
  - PORTA.0 : Push Button Entry (active LOW)
  - PORTA.1 : IR Sensor Exit   (active LOW)
  - PORTB.0 : LED OK   (green)
  - PORTB.1 : LED FULL (red)
  - PORTB.2 : Gate IN
  - PORTB.3 : Gate OUT
  - PORTC   : LCD 16x2 (4-bit)
  - PORTD.0 : RXD (UART)
  - PORTD.1 : TXD (UART)
*****************************************************/

#include <mega16.h>      // <-- ATmega16
#include <delay.h>
#include <stdio.h>
#include <string.h>
#include <stdlib.h>

#pragma warn-

/* ------------------------------------------------
   LCD pins (PORTC, 4-bit)
   ------------------------------------------------ */
#define LCD_RS      PORTC.0
#define LCD_RW      PORTC.1
#define LCD_EN      PORTC.2
#define LCD_D4      PORTC.4
#define LCD_D5      PORTC.5
#define LCD_D6      PORTC.6
#define LCD_D7      PORTC.7

#define LCD_RS_DIR  DDRC.0
#define LCD_RW_DIR  DDRC.1
#define LCD_EN_DIR  DDRC.2
#define LCD_D4_DIR  DDRC.4
#define LCD_D5_DIR  DDRC.5
#define LCD_D6_DIR  DDRC.6
#define LCD_D7_DIR  DDRC.7

/* ------------------------------------------------
   I/O pins
   ------------------------------------------------ */
#define SENSOR_ENTRY  PINA.0
#define SENSOR_EXIT   PINA.1

#define LED_OK        PORTB.0
#define LED_FULL      PORTB.1
#define GATE_IN       PORTB.2
#define GATE_OUT      PORTB.3

/* ------------------------------------------------
   Config
   ------------------------------------------------ */
#define CAPACITY      10
#define GATE_OPEN_MS  1500
#define DEBOUNCE_MS   50

/* ------------------------------------------------
   UART - ATmega16 @ 8MHz -> 9600 baud
   UBRR = (8000000 / (16 * 9600)) - 1 = 51
   ------------------------------------------------ */
#define UBRR_VAL    51
#define RX_BUF_SIZE 32       // ATmega16: 1KB RAM, buffer śµŹśØ╩č

volatile char          rx_buffer[RX_BUF_SIZE];
volatile unsigned char rx_index = 0;
volatile unsigned char rx_ready = 0;

volatile int cars = 0;

/* ------------------------------------------------
   UART - ATmega16
   č╠Ēė╩čÕŪ ╚Ū ATmega32 ĒśėŪõ Ūė╩ ŪŃŪ
   UCSRC ╚ŪĒŽ ╚Ū URSEL=1 õµį╩Õ įµŽ (shared address ╚Ū UBRRH)
   ------------------------------------------------ */
void uart_init(void) {
    UBRRH = 0;
    UBRRL = UBRR_VAL;
    UCSRB = (1 << RXCIE) | (1 << TXEN) | (1 << RXEN);
    // URSEL=1 ╚čŪĒ õµį╩õ čµĒ UCSRC (õÕ UBRRH)
    UCSRC = (1 << URSEL) | (1 << UCSZ1) | (1 << UCSZ0); // 8N1
}

interrupt [USART_RXC] void usart_rx_isr(void) {
    char c = UDR;
    if (rx_ready) return;
    if (c == '\n' || c == '\r') {
        if (rx_index > 0) {
            rx_buffer[rx_index] = '\0';
            rx_ready = 1;
            rx_index = 0;
        }
    } else {
        if (rx_index < RX_BUF_SIZE - 1)
            rx_buffer[rx_index++] = c;
        else
            rx_index = 0;
    }
}

void uart_send_char(char c) {
    while (!(UCSRA & (1 << UDRE)));
    UDR = c;
}

void uart_send_string(char *s) {
    while (*s) uart_send_char(*s++);
}

void uart_send_state(char *event) {
    char buf[100];
    char status[12];
    int avail = CAPACITY - cars;

    if (cars >= CAPACITY)
        strcpy(status, "full");
    else
        strcpy(status, "available");

    sprintf(buf,
        "{\"cars\":%d,\"capacity\":%d,\"available\":%d,\"status\":\"%s\",\"event\":\"%s\"}\r\n",
        cars,
        CAPACITY,
        avail,
        status,
        event);

    uart_send_string(buf);
}

/* ------------------------------------------------
   Command parser
   {"cmd":"open_gate_in"}
   {"cmd":"open_gate_out"}
   ------------------------------------------------ */
void parse_command(char *str) {
uart_send_state("cmd_received");
    if (strstr(str, "open_gate_in")) {
        GATE_IN = 1;
        delay_ms(GATE_OPEN_MS);
        GATE_IN = 0;
        uart_send_state("manual_in");
    } else if (strstr(str, "open_gate_out")) {
        GATE_OUT = 1;
        delay_ms(GATE_OPEN_MS);
        GATE_OUT = 0;
        uart_send_state("manual_out");
    }
}

/* ------------------------------------------------
   LCD (4-bit mode)
   ------------------------------------------------ */
void lcd_pulse(void) {
    LCD_EN = 1;
    delay_us(1);
    LCD_EN = 0;
    delay_us(100);
}

void lcd_nibble(unsigned char n) {
    LCD_D4 = (n >> 0) & 1;
    LCD_D5 = (n >> 1) & 1;
    LCD_D6 = (n >> 2) & 1;
    LCD_D7 = (n >> 3) & 1;
    lcd_pulse();
}

void lcd_byte(unsigned char b) {
    lcd_nibble(b >> 4);
    lcd_nibble(b & 0x0F);
}

void lcd_cmd(unsigned char c) {
    LCD_RS = 0;
    LCD_RW = 0;
    lcd_byte(c);
    delay_ms(2);
}

void lcd_char(unsigned char c) {
    LCD_RS = 1;
    LCD_RW = 0;
    lcd_byte(c);
    delay_ms(1);
}

void lcd_init(void) {
    LCD_RS_DIR = 1; LCD_RW_DIR = 1; LCD_EN_DIR = 1;
    LCD_D4_DIR = 1; LCD_D5_DIR = 1; LCD_D6_DIR = 1; LCD_D7_DIR = 1;

    delay_ms(50);
    LCD_RS = 0; LCD_RW = 0; LCD_EN = 0;

    lcd_nibble(0x03); delay_ms(5);
    lcd_nibble(0x03); delay_us(150);
    lcd_nibble(0x03);
    lcd_nibble(0x02);   // 4-bit mode

    lcd_cmd(0x28);      // 4-bit, 2 line, 5x8
    lcd_cmd(0x0C);      // display on, cursor off
    lcd_cmd(0x06);      // entry mode: increment, no shift
    lcd_cmd(0x01);      // clear
    delay_ms(2);
}

void lcd_clear(void) {
    lcd_cmd(0x01);
    delay_ms(2);
}

void lcd_goto(unsigned char x, unsigned char y) {
    if (y == 0)
        lcd_cmd(0x80 + x);
    else
        lcd_cmd(0xC0 + x);
}

void lcd_puts(char *s) {
    while (*s) lcd_char(*s++);
}

void lcd_puts_f(flash char *s) {
    while (*s) lcd_char(*s++);
}

/* ------------------------------------------------
   Display & LEDs
   ------------------------------------------------ */
void update_leds(void) {
    if (cars >= CAPACITY) {
        LED_FULL = 1;
        LED_OK   = 0;
    } else {
        LED_FULL = 0;
        LED_OK   = 1;
    }
}

void display_status(void) {
    char buf[17];

    lcd_goto(0, 0);
    sprintf(buf, "Cars:%2d/%2d    ", cars, CAPACITY);
    lcd_puts(buf);

    lcd_goto(0, 1);
    if (cars >= CAPACITY) {
        lcd_puts_f("*** FULL ***   ");
    } else {
        sprintf(buf, "Free:%2d       ", CAPACITY - cars);
        lcd_puts(buf);
    }
}

/* ------------------------------------------------
   Gate logic
   ------------------------------------------------ */
void handle_entry(void) {
    if (cars < CAPACITY) {
        cars++;
        GATE_IN = 1;
        delay_ms(GATE_OPEN_MS);
        GATE_IN = 0;
        display_status();
        update_leds();
        uart_send_state("enter");
    } else {
        uart_send_state("denied");
    }
    while (SENSOR_ENTRY == 0);
    delay_ms(200);
}

void handle_exit(void) {
    if (cars > 0) {
        cars--;
        GATE_OUT = 1;
        delay_ms(GATE_OPEN_MS);
        GATE_OUT = 0;
        display_status();
        update_leds();
        uart_send_state("exit");
    }
    while (SENSOR_EXIT == 0);
    delay_ms(200);
}

/* ------------------------------------------------
   Main
   ------------------------------------------------ */
void main(void) {

    DDRA  = 0x00; PORTA = 0x03;   // PA0, PA1: input + pull-up
    DDRB  = 0x0F; PORTB = 0x00;   // PB0..PB3: output
    DDRC  = 0x00; PORTC = 0x00;   // LCD init handles DDRC
    DDRD  = 0x02; PORTD = 0x00;   // PD1=TXD output, PD0=RXD input

    uart_init();
    lcd_init();
    lcd_clear();

    lcd_goto(0, 0); lcd_puts_f("Smart Parking");
    lcd_goto(0, 1); lcd_puts_f("System Ready");
    delay_ms(2000);
    lcd_clear();

    display_status();
    update_leds();
    uart_send_state("boot");

    #asm("sei")

    while (1) {
        if (rx_ready) {
            parse_command((char*)rx_buffer);
            rx_ready = 0;
        }

        if (SENSOR_ENTRY == 0) {
            delay_ms(DEBOUNCE_MS);
            if (SENSOR_ENTRY == 0)
                handle_entry();
        }

        if (SENSOR_EXIT == 0) {
            delay_ms(DEBOUNCE_MS);
            if (SENSOR_EXIT == 0)
                handle_exit();
        }

        delay_ms(10);
    }
}